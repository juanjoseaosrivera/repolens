# RepoLens — Environment Variables
# Copy to .env and fill in real values. Never commit .env itself.

# --- Application ---
REPOLENS_DEBUG=true
REPOLENS_LOG_LEVEL=DEBUG

# --- Database (PostgreSQL + pgvector) ---
REPOLENS_DATABASE_URL=postgresql+psycopg://repolens:repolens@localhost:5432/repolens

# --- Redis ---
REPOLENS_REDIS_URL=redis://localhost:6379/0

# --- LLM (Anthropic) ---
REPOLENS_ANTHROPIC_API_KEY=sk-ant-...
REPOLENS_DEFAULT_MODEL=claude-sonnet-4-6
REPOLENS_HARD_REASONING_MODEL=claude-opus-4-7
REPOLENS_LLM_MAX_TOKENS=4096
REPOLENS_LLM_TEMPERATURE=0.0

# --- Embeddings (OpenAI) ---
REPOLENS_OPENAI_API_KEY=sk-...
REPOLENS_EMBEDDING_MODEL=text-embedding-3-small
REPOLENS_EMBEDDING_DIMENSIONS=1536

# --- Server ---
REPOLENS_HOST=0.0.0.0
REPOLENS_PORT=8000
REPOLENS_CORS_ORIGINS=["http://localhost:4200"]

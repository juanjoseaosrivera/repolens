# Copy to `.env` and fill in. Never commit `.env`.

# Anthropic API key (for Claude). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key (for embeddings). Get one at https://platform.openai.com/
OPENAI_API_KEY=

# Postgres connection (matches docker/docker-compose.yml defaults).
DATABASE_URL=postgresql+psycopg://repolens:repolens@localhost:5432/repolens
